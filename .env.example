# 复制本文件为 .env，填入你自己的 key。
# API key 可在 Google AI Studio 免费申领：https://aistudio.google.com/apikey

GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# 模型标识（可选，默认 gemini-3.5-flash）。
GEMINI_MODEL=gemini-3.5-flash

# API 根地址（可选，一般不用改；走中转/代理时才需要）。
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# 思考等级（可选，默认 high——描述的文学发挥更好，但思考 token 按输出计费）。
# 有效值：minimal / low / medium / high。想省钱就改 minimal。
GEMINI_THINKING_LEVEL=high

# ── HTTP 远程模式口令（仅用 `python main.py --http` 对外提供服务时才需要）──
# 只跑本地 stdio（Claude Code / Desktop 注册）时，这一项无需理会，留着占位符即可。
# 它会被拼进公网访问地址的路径：/mcp/<这里的值>，是这个端口对外的【唯一门锁】。
# 用下面的命令生成一段足够长的随机字符串填进来（务必替换占位符，且绝不要公开/截图给别人）：
#     uv run python -c "import secrets; print(secrets.token_urlsafe(32))"
# 若开了 --http 却仍是占位符或留空，服务器会直接拒绝启动（防止裸奔上公网）。
GEMINI_MCP_HTTP_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# 公网根地址（可选，--http 模式用）：经 Cloudflare Tunnel 等暴露后的对外地址。
# get_upload_url 工具用它拼出 claude.ai 沙盒可达的上传地址；不设则只给 localhost 地址。
GEMINI_MCP_PUBLIC_BASE_URL=https://你的子域名.你的域名.com
